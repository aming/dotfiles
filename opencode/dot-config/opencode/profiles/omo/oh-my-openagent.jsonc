{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  // https://github.com/code-yeongyu/oh-my-openagent/blob/dev/docs/guide/agent-model-matching.md
  // Models:
  //   Kimi K2.5	Behaves very similarly to Claude. Great all-rounder at lower cost.
  //     Vision-capable, Claude-like reasoning. Used by Sisyphus, Atlas, Sisyphus-Junior, Multimodal Looker.
  //   GLM 5		Claude-like behavior. Solid for orchestration tasks.
  //     Text-only orchestration model. Used by Oracle, Prometheus, Metis, Momus.
  //   MiniMax M2.7	Fast and smart 
  // 	 Ultra-cheap, fast responses. Used by Librarian, Explore, Atlas, and Sisyphus-Junior for utility work.
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "agents": {
    // Communicators -> Claude / Kimi / GLM
    // GPT is still not the default recommendation for the orchestrator.
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5"
    },
    "metis": {
      // "model": "opencode-go/glm-5",
      "model": "openai/gpt-5.4",
      "variant": "max"
    },
    // Dual-Prompt Agents -> Claude preferred, GPT supported
    "prometheus": {
      // "model": "openai/gpt-5.4",
      // "model": "opencode-go/glm-5"
      "model": "opencode-go/mimo-v2-pro",
      "variant": "high"
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.5"
    },
    // Deep Specialists -> GPT
    // GPT-5.4 is built for exactly for Hephaestus
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    // Utility Runners ->  Speed over Intelligence
    "explore": {
      "model": "opencode-go/minimax-m2.5"
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "multimodal-looker": {
      "model": "opencode-go/mimo-v2-omni"
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.5"
    }
  },
  "categories": {
    "visual-engineering": {
      // "model": "google/gemini-3.1-pro-preview",
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      // "model": "opencode-go/glm-5"
      "variant": "xhigh"
    },
    "deep": {
      // "model": "openai/gpt-5.3-codex",
      "model": "opencode-go/mimo-v2-pro",
      "variant": "medium"
    },
    "quick": {
      // "model": "openai/gpt-5.1-codex-mini"
      "model": "opencode-go/minimax-m2.5"
    },
    "unspecified-low": {
      // "model": "openai/gpt-5.1-codex-mini",
      // "model": "opencode-go/kimi-k2.5"
      "model": "opencode-go/minimax-m2.7",
      "variant": "medium"
    },
    "unspecified-high": {
      // "model": "openai/gpt-5.4",
      // "model": "opencode-go/glm-5"
      "model": "opencode-go/mimo-v2-pro",
      "variant": "medium"
    },
    "writing": {
      // "model": "opencode-go/kimi-k2.5"
      "model": "opencode-go/mimo-v2-omni"
    },
    "artistry": {
      // "model": "google/gemini-3.1-pro-preview",
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high"
    }
  },
  "background_task": {
    "providerConcurrency": {
      "studio": 2,
      "openai": 3,
      "opencode-go": 10
    },
    "modelConcurrency": {
      "opencode-go/minimax-m2.7": 10,
      "opencode-go/minimax-m2.5": 10
    }
  }
}
