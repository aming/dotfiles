{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  // https://github.com/code-yeongyu/oh-my-openagent/blob/dev/docs/guide/agent-model-matching.md
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "agents": {
    // 
    // Communicators -> Opus → Sonnet, Kimi K2.5, GLM 5 (all communicative models)
    // GPT is still not the default recommendation for the orchestrator.
    // These agents have Claude-optimized prompts — long, detailed, mechanics-driven. They need models that reliably follow complex, multi-layered instructions.
    // 
    // Main orchestrator
    // claude-opus-4-7 (max) → kimi-k2.5 → gpt-5.4 (medium) → glm-5 → big-pickle
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5"
    },
    // Plan gap analyzer
    // claude-opus-4-7 (max) → gpt-5.4 (high) → glm-5 → k2p5
    "metis": {
      // "model": "opencode-go/glm-5",
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    //
    // Dual-Prompt Agents: Opus → GPT-5.4 (auto-switches to the GPT prompt)
    //
    // Strategic planner
    // claude-opus-4-7 (max) → gpt-5.4 (high) → glm-5 → gemini-3.1-pro
    "prometheus": {
      // "model": "openai/gpt-5.4",
      // "model": "opencode-go/glm-5"
      "model": "opencode-go/mimo-v2-pro",
      "variant": "high"
    },
    // Todo orchestrator
    // claude-sonnet-4-6 → kimi-k2.5 → gpt-5.4 (medium) → minimax-m2.7
    "atlas": {
      "model": "opencode-go/kimi-k2.5"
    },
    //
    // Deep Specialists -> GPT
    // These agents are built for GPT's principle-driven style. Their prompts assume autonomous, goal-oriented execution. Don't override to Claude.
    //
    // Autonomous deep worker
    // gpt-5.4 (medium)
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    // Architecture consultant
    // gpt-5.4 (high) → gemini-3.1-pro (high) → claude-opus-4-7 (max) → glm-5
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    // Ruthless reviewer
    // gpt-5.4 (xhigh) → claude-opus-4-7 (max) → gemini-3.1-pro (high) → glm-5
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    //
    // Utility Runners ->  Speed over Intelligence
    // These agents do grep, search, and retrieval. They intentionally use the fastest, cheapest models available. Don't "upgrade" them to Opus — that's hiring a senior engineer to file paperwork.
    //
    // Fast codebase grep
    // gpt-5.4-mini-fast → minimax-m2.7[-highspeed] → claude-haiku-4-5 → gpt-5.4-nano
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    // Docs/code search
    // gpt-5.4-mini-fast → minimax-m2.7[-highspeed] → claude-haiku-4-5 → gpt-5.4-nano
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    // Vision/screenshots
    // gpt-5.4 (medium) → kimi-k2.5 → glm-4.6v → gpt-5-nano
    "multimodal-looker": {
      "model": "opencode-go/mimo-v2-omni"
    },
    // Category executor
    // claude-sonnet-4-6 → kimi-k2.5 → gpt-5.4 (medium) → minimax-m2.7 → big-pickle
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.5"
    }
  },
  "categories": {
    // Frontend, UI, CSS, design
    // gemini-3.1-pro (high) → glm-5 → opus-4-7 (max) → glm-5 → kimi-k2.5
    "visual-engineering": {
      // "model": "google/gemini-3.1-pro-preview",
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high"
    },
    // Maximum reasoning needed
    // gpt-5.4 (xhigh) → gemini-3.1-pro (high) → claude-opus-4-7 (max) → glm-5
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      // "model": "opencode-go/glm-5"
      "variant": "xhigh"
    },
    // Deep coding, complex logic
    // gpt-5.4 (medium) → claude-opus-4-7 (max) → gemini-3.1-pro (high)
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    // Creative, novel approaches
    // gemini-3.1-pro (high) → claude-opus-4-7 (max) → gpt-5.4
    "artistry": {
      // "model": "google/gemini-3.1-pro-preview",
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high"
    },
    // Simple, fast tasks
    // gpt-5.4-mini → claude-haiku-4-5 → gemini-3-flash → minimax-m2.7 → gpt-5-nano
    "quick": {
      "model": "opencode-go/deepseek-v4-flash"
      // "model": "opencode-go/minimax-m2.7"
    },
    // General complex work
    // claude-opus-4-7 (max) → gpt-5.4 (high) → glm-5 → kimi-k2.5
    "unspecified-high": {
      // "model": "openai/gpt-5.4",
      // "model": "opencode-go/glm-5"
      "model": "opencode-go/mimo-v2-pro",
      "variant": "medium"
    },
    // General standard work
    // claude-sonnet-4-6 → gpt-5.3-codex (medium) → kimi-k2.5 → gemini-3-flash → minimax-m2.7
    "unspecified-low": {
      // "model": "openai/gpt-5.1-codex-mini",
      // "model": "opencode-go/kimi-k2.5"
      "model": "opencode-go/minimax-m2.7",
      "variant": "medium"
    },
    // Text, docs, prose
    // gemini-3-flash → kimi-k2.5 → claude-sonnet-4-6 → minimax-m2.7
    "writing": {
      // "model": "opencode-go/kimi-k2.5"
      // "model": "opencode-go/mimo-v2-omni"
      "model": "opencode-go/minimax-m2.7"
    }
  },
  "background_task": {
    "providerConcurrency": {
      "studio": 2,
      "openai": 3,
      "opencode-go": 10
    },
    "modelConcurrency": {
      "opencode-go/minimax-m2.7": 10,
      "opencode-go/minimax-m2.5": 10
    }
  }
}
